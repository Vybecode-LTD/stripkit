<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StripKit.ViewModels"
        xmlns:views="clr-namespace:StripKit.Views"
        xmlns:controls="clr-namespace:StripKit.Controls"
        x:Class="StripKit.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="StripKit — Animated Control Filmstrip Maker"
        Icon="/Assets/stripkit.png"
        Width="1060" Height="740"
        MinWidth="940" MinHeight="620"
        FontFamily="Verdana, Segoe UI, Arial, sans-serif"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent">

    <Panel>
        <!-- Frosted acrylic base: real on Windows, FallbackColor elsewhere. -->
        <ExperimentalAcrylicBorder Material="{DynamicResource ObsidianAcrylic}" />

        <!-- Warm accent glow (top-right) — adds depth/atmosphere over the flat acrylic. -->
        <Border IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="86%,0%" GradientOrigin="86%,0%" RadiusX="80%" RadiusY="80%">
                    <GradientStop Offset="0" Color="#33E8440A" />
                    <GradientStop Offset="0.5" Color="#11E8440A" />
                    <GradientStop Offset="1" Color="#00E8440A" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

        <TabItem Header="Create">
            <Grid ColumnDefinitions="370,*">

        <!-- ===== LEFT: settings ===== -->
        <Border Grid.Column="0" Classes="card" Margin="12,12,6,12">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="2">

                    <TextBlock Text="StripKit" FontSize="20" FontWeight="Bold" Foreground="White" />
                    <Border Classes="divider" />
                    <TextBlock Text="Single image → animated knob / fader / slider / meter / button filmstrip"
                               Foreground="{DynamicResource Text1Brush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />

                    <!-- Source -->
                    <controls:SectionHeader Text="SOURCE IMAGE" />
                    <Button Content="Load source image…" HorizontalAlignment="Stretch"
                            ToolTip.Tip="Load a transparent PNG of your control (knob, fader, slider…). You can also drag &amp; drop it onto the preview."
                            Command="{Binding OpenSourceCommand}" />
                    <TextBlock Classes="label" Text="{Binding SourceInfo}" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <!-- Component type -->
                    <controls:SectionHeader Text="COMPONENT TYPE" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ToolTip.Tip="What you're making. StripKit applies sensible frame sizes and defaults for each type."
                              ItemsSource="{Binding ComponentTypes}"
                              SelectedItem="{Binding ComponentType}" />

                    <!-- Frames -->
                    <controls:SectionHeader Text="FRAMES" />
                    <NumericUpDown Value="{Binding FrameCount}" Minimum="2" Maximum="512" Increment="1"
                                   ToolTip.Tip="How many frames the filmstrip has. 32 / 64 / 128 are the standard choices; more = smoother but larger." />
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <Button Content="32" Command="{Binding SetFrames32Command}" />
                        <Button Content="64" Command="{Binding SetFrames64Command}" />
                        <Button Content="128" Command="{Binding SetFrames128Command}" />
                    </StackPanel>

                    <!-- Frame size -->
                    <controls:SectionHeader Text="FRAME SIZE (1x, px)" />
                    <Grid ColumnDefinitions="*,8,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="label" Text="Width" />
                            <NumericUpDown Value="{Binding FrameWidth}" Minimum="1" Maximum="4096" Increment="1" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Classes="label" Text="Height" />
                            <NumericUpDown Value="{Binding FrameHeight}" Minimum="1" Maximum="4096" Increment="1" />
                        </StackPanel>
                    </Grid>
                    <Button Content="Match frame to source size" Margin="0,6,0,0"
                            HorizontalAlignment="Stretch" Command="{Binding MatchFrameToSourceCommand}" />

                    <!-- Rotary -->
                    <StackPanel IsVisible="{Binding IsRotary}" Spacing="2">
                        <controls:SectionHeader Text="ROTATION" />
                        <TextBlock Classes="label" Text="Sweep (degrees)" />
                        <NumericUpDown Value="{Binding SweepDegrees}" Minimum="1" Maximum="360" Increment="5" />
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                            <Button Content="270°" Command="{Binding Sweep270Command}" />
                            <Button Content="300°" Command="{Binding Sweep300Command}" />
                            <Button Content="360°" Command="{Binding Sweep360Command}" />
                        </StackPanel>
                        <CheckBox Content="Clockwise (min → max)" IsChecked="{Binding RotationClockwise}" Margin="0,6,0,0" />

                        <controls:SectionHeader Text="CENTER (alignment)" />
                        <Button Content="Auto-center on content" HorizontalAlignment="Stretch"
                                Command="{Binding AutoCenterCommand}" IsEnabled="{Binding HasSource}" />
                        <CheckBox Content="Enable crosshair"
                                  IsChecked="{Binding ShowCenterGuide}" Margin="0,6,0,0" />
                        <Grid ColumnDefinitions="*,8,*" Margin="0,4,0,0">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="label" Text="Center X (0–1)" />
                                <NumericUpDown Value="{Binding SourceCenterX}" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Classes="label" Text="Center Y (0–1)" />
                                <NumericUpDown Value="{Binding SourceCenterY}" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00" />
                            </StackPanel>
                        </Grid>
                        <Button Content="Reset to image centre" HorizontalAlignment="Left"
                                Command="{Binding ResetCenterCommand}" Margin="0,4,0,0" />
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="The spin centre is auto-detected on load. If a knob still wobbles, enable the crosshair and drag it onto the knob's true centre — it updates live and the art stays put. Switch it off when done." />

                        <!-- Value arc / fill ring (Serum/Vital-style) -->
                        <controls:SectionHeader Text="VALUE ARC (fill ring)" />
                        <CheckBox Content="Add a value arc that tracks the value" IsChecked="{Binding ShowValueArc}" />
                        <StackPanel IsVisible="{Binding ShowValueArc}" Spacing="2" Margin="0,4,0,0">
                            <Grid ColumnDefinitions="*,8,*">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="label" Text="Radius (0–1)" />
                                    <NumericUpDown Value="{Binding ArcRadius}" Minimum="0.1" Maximum="1.2" Increment="0.01" FormatString="0.00" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Classes="label" Text="Thickness (px)" />
                                    <NumericUpDown Value="{Binding ArcThickness}" Minimum="0.5" Maximum="64" Increment="0.5" FormatString="0.0" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Classes="label" Text="Arc colour (#AARRGGBB)" Margin="0,4,0,0" />
                            <TextBox Text="{Binding ArcColorHex}" />
                            <CheckBox Content="Round end caps" IsChecked="{Binding ArcRoundCaps}" Margin="0,6,0,0" />
                            <CheckBox Content="Dim track behind" IsChecked="{Binding ArcTrack}" />
                            <TextBox Text="{Binding ArcTrackColorHex}" IsVisible="{Binding ArcTrack}"
                                     Watermark="track colour #AARRGGBB" />

                            <Expander Header="Gradient &amp; glow" Margin="0,6,0,0">
                                <StackPanel Spacing="2">
                                    <CheckBox Content="Gradient along the arc" IsChecked="{Binding ArcGradient}" />
                                    <TextBlock Classes="label" Text="Gradient end colour" IsVisible="{Binding ArcGradient}" />
                                    <TextBox Text="{Binding ArcColor2Hex}" IsVisible="{Binding ArcGradient}" />
                                    <CheckBox Content="Glow" IsChecked="{Binding ArcGlow}" Margin="0,6,0,0" />
                                    <TextBlock Classes="label" Text="Glow size (px)" IsVisible="{Binding ArcGlow}" />
                                    <NumericUpDown Value="{Binding ArcGlowSize}" Minimum="0" Maximum="64" Increment="0.5"
                                                   FormatString="0.0" IsVisible="{Binding ArcGlow}" />
                                </StackPanel>
                            </Expander>
                            <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="A modern fill arc composited onto every frame; it follows the rotation sweep above. Baked into the PNG." />
                        </StackPanel>

                        <!-- Layer-aware animation: a static body + a separate rotating pointer -->
                        <controls:SectionHeader Text="LAYERED KNOB (base + pointer)" />
                        <TextBlock Classes="label" TextWrapping="Wrap"
                                   Text="Optional. Load a static body and a separate pointer — only the pointer rotates, so the body stays crisp at any resolution. Leave empty to spin the single source image above as before." />

                        <!-- Import a real layered file (SVG/PSD) → N tagged layers (★ #3 step 3) -->
                        <Button Content="Import layered file (SVG / PSD)…" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                Command="{Binding ImportLayeredFileCommand}" />
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="Drop in a layered knob exported from Illustrator / Inkscape / Figma (.svg) or Photoshop (.psd). Each layer is listed below — set the body layers to Static and the indicator to Rotate. Replaces the manual base/pointer slots." />

                        <StackPanel IsVisible="{Binding HasImportedLayers}" Spacing="2" Margin="0,6,0,0">
                            <TextBlock Classes="label" Text="{Binding ImportInfo}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding ImportedLayers}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ImportedLayerRow">
                                        <Grid ColumnDefinitions="*,8,Auto" Margin="0,0,0,4">
                                            <TextBlock Grid.Column="0" Classes="label" VerticalAlignment="Center"
                                                       Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                            <ComboBox Grid.Column="2" MinWidth="98"
                                                      ItemsSource="{Binding Behaviors}" SelectedItem="{Binding Behavior}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Clear import" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                                    Command="{Binding ClearImportedLayersCommand}" />
                        </StackPanel>

                        <Separator Margin="0,10,0,6" />
                        <TextBlock Classes="label" TextWrapping="Wrap" Text="…or build a layered knob by hand:" />

                        <Button Content="Auto-extract from flat knob…" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                Command="{Binding AutoExtractPointerCommand}" />
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="Only have a flat knob (body + indicator baked together)? This splits it into a static body + a rotating pointer for you — then verify the sweep and tweak the pivot below. Works best on a round knob with one indicator." />

                        <TextBlock Classes="label" Text="Base layer (static body)" Margin="0,8,0,0" />
                        <Button Content="Load base (body)…" HorizontalAlignment="Stretch"
                                Command="{Binding OpenBaseLayerCommand}" />
                        <Button Content="Clear base" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                                IsEnabled="{Binding HasBaseLayer}" Command="{Binding ClearBaseLayerCommand}" />
                        <TextBlock Classes="label" Text="{Binding BaseLayerInfo}" TextWrapping="Wrap" Margin="0,4,0,0" />

                        <TextBlock Classes="label" Text="Pointer layer (rotates)" Margin="0,8,0,0" />
                        <Button Content="Load pointer layer…" HorizontalAlignment="Stretch"
                                Command="{Binding OpenPointerCommand}" />
                        <Button Content="Clear pointer" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                                IsEnabled="{Binding HasPointer}" Command="{Binding ClearPointerCommand}" />
                        <TextBlock Classes="label" Text="{Binding PointerInfo}" TextWrapping="Wrap" Margin="0,4,0,0" />

                        <StackPanel IsVisible="{Binding HasPointer}" Spacing="2" Margin="0,6,0,0">
                            <Grid ColumnDefinitions="*,8,*">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="label" Text="Pointer pivot X (0–1)" />
                                    <NumericUpDown Value="{Binding PointerPivotX}" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Classes="label" Text="Pointer pivot Y (0–1)" />
                                    <NumericUpDown Value="{Binding PointerPivotY}" Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00" />
                                </StackPanel>
                            </Grid>
                            <Button Content="Center pointer on body" HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Command="{Binding CenterPointerOnBodyCommand}" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="The pivot is the point the pointer rotates about (its attachment to the knob centre). Defaults to the body's detected centre." />
                        </StackPanel>

                        <Expander Header="Advanced angles / pivot" Margin="0,6,0,0">
                            <StackPanel Spacing="2">
                                <TextBlock Classes="label" Text="Start angle (frame 0)" />
                                <NumericUpDown Value="{Binding StartAngleDegrees}" Minimum="-360" Maximum="360" Increment="1" />
                                <TextBlock Classes="label" Text="End angle (last frame)" />
                                <NumericUpDown Value="{Binding EndAngleDegrees}" Minimum="-360" Maximum="360" Increment="1" />
                                <Grid ColumnDefinitions="*,8,*" Margin="0,4,0,0">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Classes="label" Text="Pivot offset X" />
                                        <NumericUpDown Value="{Binding PivotOffsetX}" Minimum="-2048" Maximum="2048" Increment="0.5" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Classes="label" Text="Pivot offset Y" />
                                        <NumericUpDown Value="{Binding PivotOffsetY}" Minimum="-2048" Maximum="2048" Increment="0.5" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- Linear -->
                    <StackPanel IsVisible="{Binding IsLinear}" Spacing="2">
                        <controls:SectionHeader Text="TRAVEL" />
                        <TextBlock Classes="label" Text="Edge margin (px)" />
                        <NumericUpDown Value="{Binding EdgeMargin}" Minimum="0" Maximum="512" Increment="1" />
                        <TextBlock Classes="label" Text="Cap cross-axis offset (px)" />
                        <NumericUpDown Value="{Binding CapCrossOffset}" Minimum="-512" Maximum="512" Increment="1" />
                        <Button Content="Auto-center cap on content" HorizontalAlignment="Stretch" Margin="0,6,0,0"
                                Command="{Binding AutoCenterCommand}" IsEnabled="{Binding HasSource}" />
                        <CheckBox Content="Enable crosshair" IsChecked="{Binding ShowCenterGuide}" Margin="0,6,0,0" />
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="The loaded image is the moving cap. Frame size above is the full track area." />
                    </StackPanel>

                    <!-- Button / Toggle -->
                    <StackPanel IsVisible="{Binding IsStateFrames}" Spacing="2">
                        <controls:SectionHeader Text="BUTTON / TOGGLE STATES" />
                        <TextBlock Classes="label" TextWrapping="Wrap"
                                   Text="A button/toggle filmstrip has one frame per UI state: frame 0 = off, frame 1 = on, frame 2 = pressed (optional), frame 3 = disabled (optional). A toggle is just the off/on pair. Set Frames above to the number of states you need." />
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="Import a layered SVG / PSD with groups named 'off' and 'on' (or 'state0', 'state1'…) — each group renders only on its matching frame. Use the Generate tab to create button/toggle art with your own AI key." />
                        <Button Content="Import layered file (SVG / PSD)…" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                Command="{Binding ImportLayeredFileCommand}" />
                        <StackPanel IsVisible="{Binding HasImportedLayers}" Spacing="2" Margin="0,6,0,0">
                            <TextBlock Classes="label" Text="{Binding ImportInfo}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding ImportedLayers}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ImportedLayerRow">
                                        <Grid ColumnDefinitions="*,8,Auto" Margin="0,0,0,4">
                                            <TextBlock Grid.Column="0" Classes="label" VerticalAlignment="Center"
                                                       Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                            <ComboBox Grid.Column="2" MinWidth="98"
                                                      ItemsSource="{Binding Behaviors}" SelectedItem="{Binding Behavior}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Clear import" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                                    Command="{Binding ClearImportedLayersCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Meter -->
                    <StackPanel IsVisible="{Binding IsMeter}" Spacing="2">
                        <controls:SectionHeader Text="METER" />
                        <TextBlock Classes="label" Text="Segments" />
                        <NumericUpDown Value="{Binding SegmentCount}" Minimum="1" Maximum="128" Increment="1" />
                        <TextBlock Classes="label" Text="Fill direction" Margin="0,6,0,0" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding FillDirections}" SelectedItem="{Binding FillDirection}" />
                        <CheckBox Content="Continuous (smooth) fill" IsChecked="{Binding ContinuousFill}" Margin="0,6,0,0" />
                        <Grid ColumnDefinitions="*,8,*" Margin="0,6,0,0">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="label" Text="On colour (#AARRGGBB)" />
                                <TextBox Text="{Binding OnColorHex}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Classes="label" Text="Off colour" />
                                <TextBox Text="{Binding OffColorHex}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="Procedural segments by default. Load a source image (on-state) — and optionally a background (off-state) — for a layered meter instead." />
                    </StackPanel>

                    <!-- Background -->
                    <controls:SectionHeader Text="STATIC BACKGROUND (optional)" />
                    <Button Content="Load background layer…" HorizontalAlignment="Stretch"
                            Command="{Binding OpenBackgroundCommand}" />
                    <Button Content="Clear background" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                            IsEnabled="{Binding HasBackground}" Command="{Binding ClearBackgroundCommand}" />
                    <TextBlock Classes="label" Text="{Binding BackgroundInfo}" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <!-- Quality / output -->
                    <controls:SectionHeader Text="QUALITY &amp; OUTPUT" />
                    <TextBlock Classes="label" Text="Supersample (anti-aliasing)" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding SupersampleOptions}"
                              SelectedItem="{Binding Supersample}" />
                    <TextBlock Classes="label" Text="Stack direction" Margin="0,6,0,0" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding StackDirections}"
                              SelectedItem="{Binding StackDirection}" />
                    <CheckBox Content="Also export @2x (HiDPI)" IsChecked="{Binding ExportAt2x}" Margin="0,8,0,0" />

                    <!-- Manifest -->
                    <controls:SectionHeader Text="MANIFEST (optional)" />
                    <CheckBox Content="Also write a skin.json manifest" IsChecked="{Binding ExportManifest}" />
                    <TextBlock Classes="label" Text="Parameter id" Margin="0,6,0,0" />
                    <TextBox Text="{Binding ParameterId}" Watermark="e.g. filterCutoff (defaults to the file name)" />
                    <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,12"
                               Text="Writes &lt;name&gt;.skin.json next to the PNG: one control bound to this parameter, ready for a JUCE LookAndFeel / skin loader." />

                    <!-- Code export — ready-to-paste loader snippets -->
                    <controls:SectionHeader Text="CODE EXPORT (loader snippets)" />
                    <CheckBox Content="Also emit ready-to-paste loader code" IsChecked="{Binding ExportCode}" />
                    <StackPanel IsVisible="{Binding ExportCode}" Spacing="2" Margin="0,4,0,0">
                        <Grid ColumnDefinitions="*,*">
                            <CheckBox Grid.Column="0" Content="JUCE" IsChecked="{Binding EmitCodeJuce}" />
                            <CheckBox Grid.Column="1" Content="CSS / HTML" IsChecked="{Binding EmitCodeCss}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*">
                            <CheckBox Grid.Column="0" Content="iPlug2" IsChecked="{Binding EmitCodeIPlug2}" />
                            <CheckBox Grid.Column="1" Content="HISE" IsChecked="{Binding EmitCodeHise}" />
                        </Grid>
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Text="Writes a loader file per ticked target next to the PNG (.juce.h / .html / .iplug2.cpp / .hise.js). The code loads the strip and shows one frame per value." />
                    </StackPanel>

                    <Expander Header="Preview / copy code" Margin="0,6,0,12">
                        <StackPanel Spacing="6">
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding CodeTargets}" SelectedItem="{Binding CodePreviewTarget}" />
                            <Border Classes="tile" Padding="2">
                                <ScrollViewer MaxHeight="220" HorizontalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding GeneratedCode}" IsReadOnly="True" AcceptsReturn="True"
                                             TextWrapping="NoWrap" Background="Transparent" BorderThickness="0" FontSize="11" />
                                </ScrollViewer>
                            </Border>
                            <Button Content="Copy to clipboard" HorizontalAlignment="Right" Click="OnCopyCode" />
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== RIGHT: preview + export ===== -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="6,12,12,12">

            <!-- Preview doubles as a drop zone: drop a PNG here to load it as the
                 source (see MainWindow.axaml.cs). BorderBrush is flipped to the
                 accent while a file is dragged over it. -->
            <Border Grid.Row="0" x:Name="PreviewBorder" DragDrop.AllowDrop="True"
                    Background="{DynamicResource GlassFillGradient}" CornerRadius="12" ClipToBounds="True"
                    BorderThickness="2" BorderBrush="Transparent"
                    BoxShadow="0 2 6 0 #44000000, 0 18 44 0 #7A000000">
                <Border.Transitions>
                    <Transitions>
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                    </Transitions>
                </Border.Transitions>
                <Panel>
                    <Image x:Name="PreviewImageControl" Source="{Binding PreviewImage}" Stretch="Uniform" Margin="24"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />

                    <!-- Alignment guide: a draggable crosshair over the raw source. Shown
                         only in align mode (ShowCenterGuide); positioned in code-behind. -->
                    <Canvas x:Name="GuideCanvas" Margin="24" Background="Transparent"
                            IsVisible="{Binding ShowCenterGuide}" Cursor="Cross">
                        <Rectangle x:Name="CrossH" Height="1.5" Fill="{DynamicResource AccentBrush}" Opacity="0.9" />
                        <Rectangle x:Name="CrossV" Width="1.5" Fill="{DynamicResource AccentBrush}" Opacity="0.9" />
                        <Ellipse x:Name="CrossRing" Width="22" Height="22"
                                 Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" />
                    </Canvas>

                    <TextBlock Text="Drag the crosshair onto the knob's centre — it updates live"
                               IsVisible="{Binding ShowCenterGuide}" Margin="0,12"
                               HorizontalAlignment="Center" VerticalAlignment="Top"
                               Foreground="{DynamicResource Text2Brush}" FontSize="12" />

                    <TextBlock Text="Load a source image to begin — or drop a PNG here"
                               IsVisible="{Binding ShowLoadHint}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource Text3Brush}" />
                </Panel>
            </Border>

            <Border Grid.Row="1" Classes="tile" Margin="0,12,0,0">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <Button Content="◀" Click="OnStepBack" Width="40" ToolTip.Tip="Previous frame" />
                            <Button x:Name="PlayButton" Content="▶ Play" Click="OnPlayClick" Width="84" />
                            <Button Content="▶" Click="OnStepForward" Width="40" ToolTip.Tip="Next frame" />
                            <Button Content="Reset" Click="OnResetPreview" ToolTip.Tip="Reset to the centred start frame" />
                        </StackPanel>
                        <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding PreviewValue}" Margin="12,0" />
                        <TextBlock Grid.Column="2" Text="{Binding PreviewReadout}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Text2Brush}" MinWidth="160" TextAlignment="Right" />
                    </Grid>

                    <TextBlock Text="{Binding StripDimensions}" Foreground="{DynamicResource Text3Brush}" FontSize="12" />

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Text2Brush}" TextWrapping="Wrap" Margin="0,0,12,0" />
                        <Button Grid.Column="1" Classes="accent" Content="Export filmstrip PNG" MinWidth="190"
                                ToolTip.Tip="Render and save the stacked PNG filmstrip (plus @2x and a skin.json manifest if those are ticked)."
                                Command="{Binding ExportCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
            </Grid>
        </TabItem>

        <TabItem Header="Import">
            <views:ImporterView DataContext="{Binding Importer}" />
        </TabItem>

        <TabItem Header="Batch">
            <views:BatchView DataContext="{Binding Batch}" />
        </TabItem>

        <TabItem Header="Skin">
            <views:SkinView DataContext="{Binding Skin}" />
        </TabItem>

        <TabItem Header="Generate">
            <views:GenerateView DataContext="{Binding Generate}" />
        </TabItem>

        </TabControl>

        <!-- Header right side: app wordmark + a Help button + an About (?) button, across from the tabs. -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal"
                    Margin="0,18,18,0" Spacing="12">
            <Image Source="/Assets/software_logo.png" Height="26" VerticalAlignment="Center"
                   IsHitTestVisible="False" RenderOptions.BitmapInterpolationMode="HighQuality" />
            <Button Content="Help" VerticalAlignment="Center"
                    ToolTip.Tip="Open the Getting Started guide for the current tab"
                    Command="{Binding Tutorial.OpenCommand}"
                    CommandParameter="{Binding SelectedTabIndex}" />
            <Button Content="?" Width="28" Height="28" CornerRadius="14" Padding="0" FontSize="15"
                    VerticalAlignment="Center" ToolTip.Tip="About StripKit"
                    Command="{Binding ShowAboutCommand}" />
        </StackPanel>

        <!-- Getting Started guided overlay (top layer; hides itself when closed). -->
        <views:TutorialOverlay DataContext="{Binding Tutorial}" />

        <!-- About modal: a centred, drop-shadowed solid card over a dimming scrim. -->
        <Grid IsVisible="{Binding IsAboutOpen}">
            <Border Background="#99000000" />
            <Border Classes="dialog" MaxWidth="440" Padding="26"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <Image Grid.Column="0" Grid.RowSpan="4" Source="/Assets/stripkit.png"
                           Width="64" Height="64" Margin="0,0,18,0" VerticalAlignment="Top"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />
                    <TextBlock Grid.Column="1" Grid.Row="0" FontSize="15" FontWeight="SemiBold" Foreground="White"
                               Text="{Binding AppVersion, StringFormat='StripKit Filmstrip Generator v{0}'}" />
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="https://stripkit.pro" Tag="https://stripkit.pro"
                               Background="Transparent" PointerPressed="OnAboutLinkTapped" Cursor="Hand"
                               Foreground="{DynamicResource AccentHiBrush}" Margin="0,4,0,0" />
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="VybeCode Software"
                               Foreground="{DynamicResource Text2Brush}" Margin="0,8,0,0" />
                    <TextBlock Grid.Column="1" Grid.Row="3" Text="https://vybeco.de" Tag="https://vybeco.de"
                               Background="Transparent" PointerPressed="OnAboutLinkTapped" Cursor="Hand"
                               Foreground="{DynamicResource AccentHiBrush}" Margin="0,4,0,0" />
                    <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" Content="Close"
                            HorizontalAlignment="Right" Margin="0,20,0,0"
                            Command="{Binding CloseAboutCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>
