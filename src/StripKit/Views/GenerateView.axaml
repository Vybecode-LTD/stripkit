<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StripKit.ViewModels"
             xmlns:controls="clr-namespace:StripKit.Controls"
             xmlns:helpers="clr-namespace:StripKit.Helpers"
             x:Class="StripKit.Views.GenerateView"
             x:DataType="vm:GenerateViewModel">

    <UserControl.Resources>
        <helpers:HexToColorBrushConverter x:Key="HexColor" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="370,*">

        <!-- ===== LEFT: provider, key, prompt ===== -->
        <Border Grid.Column="0" Classes="card" Margin="12,12,6,12">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="2">

                    <TextBlock Text="Generate" FontSize="20" FontWeight="Bold" Foreground="White" />
                    <Border Classes="divider" />
                    <TextBlock Text="Generate a layered knob SVG with your own AI key — a static body plus a rotating pointer."
                               Foreground="{DynamicResource Text1Brush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />

                    <!-- Provider & key -->
                    <controls:SectionHeader Text="PROVIDER &amp; API KEY" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ToolTip.Tip="Which AI service to use. You supply your own API key for the one you pick."
                              ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" />

                    <TextBlock Classes="label" Text="API key" Margin="0,6,0,0" />
                    <TextBox x:Name="KeyBox" Text="{Binding ApiKey}" PasswordChar="●"
                             Watermark="paste your key (sk-… / AIza… )"
                             ToolTip.Tip="Stored encrypted with your Windows account (DPAPI). Sent only to the provider you choose." />
                    <CheckBox Content="Show key" IsChecked="{Binding #KeyBox.RevealPassword}" Margin="0,4,0,0" />
                    <Grid ColumnDefinitions="*,6,*" Margin="0,6,0,0">
                        <Button Grid.Column="0" Content="Save key" HorizontalAlignment="Stretch"
                                Command="{Binding SaveKeyCommand}" />
                        <Button Grid.Column="2" Content="Clear key" HorizontalAlignment="Stretch"
                                Command="{Binding ClearKeyCommand}" />
                    </Grid>
                    <TextBlock Classes="label" Text="{Binding KeyStatus}" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <StackPanel IsVisible="{Binding IsCustomProvider}" Spacing="2">
                        <TextBlock Classes="label" Text="Endpoint base URL" Margin="0,8,0,0" />
                        <TextBox Text="{Binding CustomBaseUrl}"
                                 Watermark="https://openrouter.ai/api/v1  (or http://localhost:11434/v1)"
                                 ToolTip.Tip="Any OpenAI-compatible chat-completions endpoint (OpenRouter, Ollama, LM Studio…). Then type the model id your endpoint expects below." />
                    </StackPanel>

                    <TextBlock Classes="label" Text="Model" Margin="0,8,0,0" />
                    <AutoCompleteBox HorizontalAlignment="Stretch"
                                     ItemsSource="{Binding SuggestedModels}" Text="{Binding Model}"
                                     FilterMode="Contains" MinimumPrefixLength="0"
                                     Watermark="model id (type, or pick a suggestion)"
                                     ToolTip.Tip="Type any model id, or pick a suggestion. Switching provider resets this to its default — handy if your preferred model isn't listed or one is retired." />

                    <!-- What to make -->
                    <controls:SectionHeader Text="WHAT TO MAKE" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding GenerateComponentTypes}"
                              SelectedItem="{Binding GenerateControlType}"
                              ToolTip.Tip="What kind of control to generate. Knobs, buttons, toggles and meters produce layered SVGs (knob = body+pointer; button/toggle/meter = off+on); faders and sliders produce a single cap/handle shape." />

                    <CheckBox Content="Horizontal meter (fills left → right)"
                              IsChecked="{Binding MeterHorizontal}"
                              IsVisible="{Binding IsMeterType}"
                              Margin="0,6,0,0"
                              ToolTip.Tip="Generate a wide meter that fills left to right. Unchecked = a tall meter that fills bottom to top." />

                    <TextBlock Classes="label" Text="Style" Margin="0,8,0,0" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding Styles}" SelectedItem="{Binding Style}" />

                    <!-- Colours -->
                    <controls:SectionHeader Text="COLOURS" />
                    <TextBlock Classes="label" Text="Click the swatch to open a colour picker, or type a hex value." Margin="0,0,0,4" />
                    <Grid ColumnDefinitions="*,8,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Classes="label" Text="Body colour" />
                            <Grid ColumnDefinitions="*,6,28">
                                <TextBox Grid.Column="0" Text="{Binding BodyColorHex}" Watermark="auto (model chooses)" />
                                <Button Grid.Column="2" Padding="0" Background="Transparent" BorderThickness="0"
                                        Width="28" Height="24"
                                        ToolTip.Tip="Click to pick a body colour"
                                        Click="OnBodyColorClick">
                                    <Border CornerRadius="4" ClipToBounds="True" Width="28" Height="24"
                                            Background="{Binding BodyColorHex, Converter={StaticResource HexColor}}"
                                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" />
                                </Button>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Classes="label" Text="Accent colour" />
                            <Grid ColumnDefinitions="*,6,28">
                                <TextBox Grid.Column="0" Text="{Binding AccentColorHex}" Watermark="#E8440A" />
                                <Button Grid.Column="2" Padding="0" Background="Transparent" BorderThickness="0"
                                        Width="28" Height="24"
                                        ToolTip.Tip="Click to pick an accent colour"
                                        Click="OnAccentColorClick">
                                    <Border CornerRadius="4" ClipToBounds="True" Width="28" Height="24"
                                            Background="{Binding AccentColorHex, Converter={StaticResource HexColor}}"
                                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Effects -->
                    <controls:SectionHeader Text="EFFECTS" />
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="Drop shadow" IsChecked="{Binding HasDropShadow}" Margin="0,0,12,0" />
                        <CheckBox Content="Outer glow" IsChecked="{Binding HasOuterGlow}" Margin="0,0,12,0" />
                        <CheckBox Content="Bevel / 3D" IsChecked="{Binding HasBevel}" Margin="0,0,12,0" />
                        <CheckBox Content="Metallic sheen" IsChecked="{Binding HasMetallicSheen}" />
                    </WrapPanel>

                    <TextBlock Classes="label" Text="Extra direction (optional)" Margin="0,8,0,0" />
                    <TextBox Text="{Binding StyleNotes}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56"
                             Watermark="e.g. amber LED ring, knurled edge, brushed aluminium face" />

                    <TextBlock Classes="label" Text="Avoid (optional)" Margin="0,8,0,0" />
                    <TextBox Text="{Binding Avoid}" TextWrapping="Wrap"
                             Watermark="e.g. no text, no numbers, no photo-realism"
                             ToolTip.Tip="Things the model should NOT include — folded into every generation, single or set." />

                    <TextBlock Classes="label" Text="Canvas size (px)" Margin="0,8,0,0" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding CanvasSizes}" SelectedItem="{Binding CanvasSize}" />

                    <Grid ColumnDefinitions="*,8,Auto" Margin="0,12,0,0">
                        <Button Grid.Column="0" Classes="accent" Content="Generate" HorizontalAlignment="Stretch"
                                ToolTip.Tip="Generate a fresh knob. Click again to regenerate a new take."
                                Command="{Binding GenerateCommand}" />
                        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}" />
                    </Grid>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsGenerating}" Margin="0,8,0,0" />

                    <Grid ColumnDefinitions="*,8,Auto" Margin="0,6,0,0">
                        <Button Grid.Column="0" Content="Generate variations" HorizontalAlignment="Stretch"
                                ToolTip.Tip="Generate several takes of the selected control at once, then pick your favourite."
                                Command="{Binding GenerateVariationsCommand}" />
                        <ComboBox Grid.Column="2" MinWidth="64"
                                  ItemsSource="{Binding VariationCounts}" SelectedItem="{Binding VariationCount}"
                                  ToolTip.Tip="How many takes to generate." />
                    </Grid>

                    <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,8,0,8"
                               Text="Each Generate is a new attempt — regenerate until you like it. Your key stays encrypted on this PC." />

                    <!-- Matching set -->
                    <controls:SectionHeader Text="MATCHING SET" />
                    <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,0,0,6"
                               Text="Generate a whole family of controls at once, all sharing the style, colours, effects and avoid-list above — a head start on a full, consistent skin." />
                    <ItemsControl ItemsSource="{Binding SetTypeOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SetTypeOption">
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding Include}" Margin="0,0,12,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid ColumnDefinitions="*,8,Auto" Margin="0,8,0,0">
                        <Button Grid.Column="0" Classes="accent" Content="Generate set" HorizontalAlignment="Stretch"
                                ToolTip.Tip="Generate every ticked control at once, in one consistent style."
                                Command="{Binding GenerateSetCommand}" />
                        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelSetCommand}" />
                    </Grid>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsGeneratingSet}" Margin="0,8,0,0" />
                    <TextBlock Classes="label" Text="{Binding SetStatus}" TextWrapping="Wrap" Margin="0,4,0,12" />

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== RIGHT: preview + actions ===== -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="6,12,12,12">

            <Border Grid.Row="0" Background="{DynamicResource GlassFillGradient}" CornerRadius="12" ClipToBounds="True"
                    BoxShadow="0 2 6 0 #44000000, 0 18 44 0 #7A000000">
                <Panel>
                    <!-- Single-control preview -->
                    <Panel IsVisible="{Binding !HasSetResults}">
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="24"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <TextBlock Text="Your generated control preview appears here"
                                   IsVisible="{Binding !HasPreview}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Text3Brush}" />
                    </Panel>

                    <!-- Matching-set results grid -->
                    <ScrollViewer IsVisible="{Binding HasSetResults}" Padding="12">
                        <ItemsControl ItemsSource="{Binding SetResults}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GeneratedSetResult">
                                    <Border Classes="tile" Width="190" Margin="6" Padding="8">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Label}" FontWeight="Bold" Foreground="White" />
                                            <Border Height="120" Background="{DynamicResource GlassFillGradient}"
                                                    CornerRadius="8" ClipToBounds="True">
                                                <Panel>
                                                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="8"
                                                           RenderOptions.BitmapInterpolationMode="HighQuality"
                                                           IsVisible="{Binding HasPreview}" />
                                                    <TextBlock Text="no preview" IsVisible="{Binding !HasPreview}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource Text3Brush}" FontSize="11" />
                                                </Panel>
                                            </Border>
                                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Text2Brush}"
                                                       FontSize="11" TextWrapping="Wrap" />
                                            <Button Content="Use in Create" Classes="accent" HorizontalAlignment="Stretch"
                                                    IsEnabled="{Binding IsSuccess}"
                                                    Command="{Binding $parent[ItemsControl].((vm:GenerateViewModel)DataContext).UseSetItemInCreateCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Grid ColumnDefinitions="*,6,*">
                                                <Button Grid.Column="0" Content="Save" HorizontalAlignment="Stretch"
                                                        IsEnabled="{Binding IsSuccess}"
                                                        Command="{Binding $parent[ItemsControl].((vm:GenerateViewModel)DataContext).SaveSetItemCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="2" Content="Regenerate" HorizontalAlignment="Stretch"
                                                        Command="{Binding $parent[ItemsControl].((vm:GenerateViewModel)DataContext).RegenerateSetItemCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Panel>
            </Border>

            <Border Grid.Row="1" Classes="tile" Margin="0,12,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               Foreground="{DynamicResource Text2Brush}" TextWrapping="Wrap" />

                    <Grid ColumnDefinitions="Auto,8,Auto,8,Auto">
                        <Button Grid.Column="0" Classes="accent" Content="Use in Create" MinWidth="140"
                                ToolTip.Tip="Send this to the Create tab as a layered import, ready to make the filmstrip."
                                Command="{Binding UseInCreateCommand}" />
                        <Button Grid.Column="2" Content="Save SVG…" Command="{Binding SaveSvgCommand}" />
                        <Button Grid.Column="4" Content="Copy SVG" Click="OnCopySvg" IsEnabled="{Binding HasResult}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,8,Auto" IsVisible="{Binding HasResult}">
                        <TextBox Grid.Column="0" Text="{Binding RefineInstruction}"
                                 Watermark="describe a change, e.g. thicker pointer, warmer accent"
                                 ToolTip.Tip="Send the current SVG back to the model with this change — keeps the same structure, tweaks what you ask." />
                        <Button Grid.Column="2" Content="Refine" Command="{Binding RefineCommand}" />
                    </Grid>

                    <Button Content="Save set…" Classes="accent" HorizontalAlignment="Left" MinWidth="140"
                            IsVisible="{Binding HasSetResults}"
                            ToolTip.Tip="Save every generated control in the set to a folder as SVGs."
                            Command="{Binding SaveSetCommand}" />

                    <Expander Header="Model response (raw)"
                              IsVisible="{Binding LastRawResponse, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Border Classes="tile" Padding="2">
                            <ScrollViewer MaxHeight="160" HorizontalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding LastRawResponse}" IsReadOnly="True" AcceptsReturn="True"
                                         TextWrapping="NoWrap" Background="Transparent" BorderThickness="0" FontSize="11" />
                            </ScrollViewer>
                        </Border>
                    </Expander>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
