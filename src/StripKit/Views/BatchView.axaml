<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StripKit.ViewModels"
             xmlns:controls="clr-namespace:StripKit.Controls"
             x:Class="StripKit.Views.BatchView"
             x:DataType="vm:BatchViewModel">

    <Grid ColumnDefinitions="370,*">

        <!-- ===== LEFT: render template ===== -->
        <Border Grid.Column="0" Classes="card" Margin="12,12,6,12">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="2" IsEnabled="{Binding !IsRunning}">

                    <TextBlock Text="Batch export" FontSize="20" FontWeight="Bold" Foreground="White" />
                    <Border Classes="divider" />
                    <TextBlock Text="Render one filmstrip per source image in a folder, using one template."
                               Foreground="{DynamicResource Text1Brush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />

                    <controls:SectionHeader Text="COMPONENT TYPE" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding ComponentTypes}" SelectedItem="{Binding ComponentType}" />

                    <controls:SectionHeader Text="FRAMES" />
                    <NumericUpDown Value="{Binding FrameCount}" Minimum="2" Maximum="512" Increment="1" />

                    <controls:SectionHeader Text="FRAME SIZE (1x, px)" />
                    <Grid ColumnDefinitions="*,8,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="label" Text="Width" />
                            <NumericUpDown Value="{Binding FrameWidth}" Minimum="1" Maximum="4096" Increment="1" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Classes="label" Text="Height" />
                            <NumericUpDown Value="{Binding FrameHeight}" Minimum="1" Maximum="4096" Increment="1" />
                        </StackPanel>
                    </Grid>
                    <CheckBox Content="Square knob frames to each source" IsChecked="{Binding MatchKnobFrameToSource}" Margin="0,6,0,0" />

                    <StackPanel IsVisible="{Binding IsRotary}" Spacing="2">
                        <controls:SectionHeader Text="ROTATION" />
                        <TextBlock Classes="label" Text="Sweep (degrees)" />
                        <NumericUpDown Value="{Binding SweepDegrees}" Minimum="1" Maximum="360" Increment="5" />
                        <CheckBox Content="Clockwise (min → max)" IsChecked="{Binding RotationClockwise}" Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsMeter}" Spacing="2">
                        <controls:SectionHeader Text="METER" />
                        <TextBlock Classes="label" Text="Segments" />
                        <NumericUpDown Value="{Binding SegmentCount}" Minimum="1" Maximum="128" Increment="1" />
                        <TextBlock Classes="label" Text="Fill direction" Margin="0,6,0,0" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding FillDirections}" SelectedItem="{Binding FillDirection}" />
                        <CheckBox Content="Continuous (smooth) fill" IsChecked="{Binding ContinuousFill}" Margin="0,6,0,0" />
                        <Grid ColumnDefinitions="*,8,*" Margin="0,6,0,0">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="label" Text="On colour (#AARRGGBB)" />
                                <TextBox Text="{Binding OnColorHex}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Classes="label" Text="Off colour" />
                                <TextBox Text="{Binding OffColorHex}" />
                            </StackPanel>
                        </Grid>
                        <CheckBox Content="Source is a backdrop (draw procedural LEDs on top)"
                                  IsChecked="{Binding MeterSourceIsBackdrop}" Margin="0,8,0,0" />
                        <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="Off: each source is the lit (on-state) art, revealed up to the fill. On: each source is a housing/backdrop and procedural LED segments are drawn over it (segments + colours apply)." />
                    </StackPanel>

                    <controls:SectionHeader Text="QUALITY &amp; OUTPUT" />
                    <TextBlock Classes="label" Text="Supersample (anti-aliasing)" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding SupersampleOptions}" SelectedItem="{Binding Supersample}" />
                    <TextBlock Classes="label" Text="Stack direction" Margin="0,6,0,0" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding StackDirections}" SelectedItem="{Binding StackDirection}" />
                    <CheckBox Content="Also export a HiDPI copy" IsChecked="{Binding ExportAt2x}" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ExportAt2x}" Margin="0,4,0,4">
                        <TextBlock Classes="label" Text="Scale" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding HiDpiScales}" SelectedItem="{Binding HiDpiScale}" MinWidth="70" />
                        <TextBlock Classes="label" Text="× (@2x / @3x / @4x)" VerticalAlignment="Center" />
                    </StackPanel>
                    <CheckBox Content="Also write a skin.json per strip" IsChecked="{Binding ExportManifest}" />

                    <controls:SectionHeader Text="CODE EXPORT (per strip)" />
                    <CheckBox Content="Also emit ready-to-paste loader code" IsChecked="{Binding ExportCode}" />
                    <StackPanel IsVisible="{Binding ExportCode}" Spacing="2" Margin="0,4,0,12">
                        <Grid ColumnDefinitions="*,*">
                            <CheckBox Grid.Column="0" Content="JUCE" IsChecked="{Binding EmitCodeJuce}" />
                            <CheckBox Grid.Column="1" Content="CSS / HTML" IsChecked="{Binding EmitCodeCss}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*">
                            <CheckBox Grid.Column="0" Content="iPlug2" IsChecked="{Binding EmitCodeIPlug2}" />
                            <CheckBox Grid.Column="1" Content="HISE" IsChecked="{Binding EmitCodeHise}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*">
                            <CheckBox Grid.Column="0" Content="React / Web" IsChecked="{Binding EmitCodeReact}" />
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== RIGHT: folders, run, progress ===== -->
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" Margin="6,12,12,12">

            <StackPanel Grid.Row="0" Spacing="2" IsEnabled="{Binding !IsRunning}">
                <controls:SectionHeader Text="INPUT FOLDER" />
                <Button Content="Choose input folder…" HorizontalAlignment="Stretch"
                        Command="{Binding ChooseInputFolderCommand}" />
                <TextBlock Classes="label" Text="{Binding InputFolder}" TextWrapping="Wrap" Margin="0,4,0,0" />
                <TextBlock Classes="label" Text="{Binding InputSummary}" />

                <controls:SectionHeader Text="OUTPUT FOLDER" />
                <Button Content="Choose output folder…" HorizontalAlignment="Stretch"
                        Command="{Binding ChooseOutputFolderCommand}" />
                <TextBlock Classes="label" Text="{Binding OutputFolder}" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="1" Classes="tile" Margin="0,16,0,0">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="accent" Content="Run batch" MinWidth="140"
                                Command="{Binding RunCommand}" />
                        <Button Content="Cancel" MinWidth="90" Command="{Binding CancelCommand}" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}"
                                 Height="6" IsVisible="{Binding IsRunning}" />
                    <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource Text2Brush}" FontSize="12" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Text2Brush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Classes="card" Margin="0,12,0,0" Padding="12">
                <ScrollViewer>
                    <TextBlock Text="{Binding ResultSummary}" Foreground="{DynamicResource Text2Brush}"
                               FontSize="12" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
