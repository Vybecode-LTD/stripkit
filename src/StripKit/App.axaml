<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StripKit.Controls"
             x:Class="StripKit.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Depth design system tokens (additive — defines the Depth* brushes /
                     radii / shadows / fonts). Applied per-subtree; currently the Create
                     tab maps StripKit's keys onto these. See C:\DEV\depth-design-system. -->
                <ResourceInclude Source="avares://StripKit/Depth/Depth.axaml" />
            </ResourceDictionary.MergedDictionaries>

        <!-- Fluent accent (checkboxes, sliders, focus, selection) → Depth ember (#f25914). -->
        <Color x:Key="SystemAccentColor">#FFF25914</Color>
        <Color x:Key="SystemAccentColorDark1">#FFDB4E0F</Color>
        <Color x:Key="SystemAccentColorDark2">#FFCC3C00</Color>
        <Color x:Key="SystemAccentColorDark3">#FFB33500</Color>
        <Color x:Key="SystemAccentColorLight1">#FFFF6E22</Color>
        <Color x:Key="SystemAccentColorLight2">#FFFF8030</Color>
        <Color x:Key="SystemAccentColorLight3">#FFFF9450</Color>

        <!-- ===== Depth design tokens (machined-grey, dark): StripKit's keys mapped onto the Depth*
             tokens from the merged Depth.axaml. See C:\DEV\depth-design-system. ===== -->
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource DepthEmberColor}" />
        <SolidColorBrush x:Key="AccentHiBrush" Color="{StaticResource DepthEmberHiColor}" />
        <SolidColorBrush x:Key="Text1Brush" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource DepthInkDimColor}" />
        <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource DepthInkFaintColor}" />
        <SolidColorBrush x:Key="GlassFillBrush" Color="{StaticResource DepthChrome2Color}" />
        <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource DepthLineSoftColor}" />
        <SolidColorBrush x:Key="GlassFillHoverBrush" Color="{StaticResource DepthChrome3Color}" />
        <SolidColorBrush x:Key="GlassPressBrush" Color="{StaticResource DepthChromeColor}" />
        <SolidColorBrush x:Key="GlassBorderHoverBrush" Color="{StaticResource DepthLineColor}" />
        <SolidColorBrush x:Key="AccentPressBrush" Color="{StaticResource DepthEmberLoColor}" />

        <!-- Primary (accent) button face = ember (top-lit). -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="{StaticResource DepthEmberHiColor}" />
            <GradientStop Offset="1" Color="{StaticResource DepthEmberLoColor}" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentGradientHover" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="{StaticResource DepthEmberHiColor}" />
            <GradientStop Offset="1" Color="{StaticResource DepthEmberColor}" />
        </LinearGradientBrush>

        <!-- Neutral buttons: a dark raised "keycap" — darker than the panel, top-lit bevel + shadow,
             clearly lighter hover (the styles live in Application.Styles below). -->
        <LinearGradientBrush x:Key="DepthButtonFace" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#2B2C2E" />
            <GradientStop Offset="1" Color="#202123" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DepthButtonFaceHover" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#3D3E40" />
            <GradientStop Offset="1" Color="#2F3032" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DepthButtonFacePressed" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#1E1F21" />
            <GradientStop Offset="1" Color="#18191B" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DepthButtonBevel" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#34FFFFFF" />
            <GradientStop Offset="0.5" Color="#12FFFFFF" />
            <GradientStop Offset="1" Color="#30000000" />
        </LinearGradientBrush>

        <!-- Inputs read as recessed dark wells (DepthInset) with a hairline border. The Fluent
             per-control keys resolve via DynamicResource, so these hit every ComboBox / TextBox /
             NumericUpDown app-wide. -->
        <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource DepthInsetColor}" />
        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource DepthChromeColor}" />
        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{StaticResource DepthInsetColor}" />
        <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource DepthInsetColor}" />
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource DepthInsetColor}" />
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource DepthInsetColor}" />
        <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource DepthLineSoftColor}" />
        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{StaticResource DepthLineColor}" />
        <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{StaticResource DepthLineSoftColor}" />
        <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource DepthLineSoftColor}" />
        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource DepthLineColor}" />
        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource DepthEmberColor}" />

        <!-- ComboBox dropdown popup + its items (the "menu"): a solid Depth panel, neutral hover, ink text. -->
        <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource DepthChromeColor}" />
        <SolidColorBrush x:Key="ComboBoxDropDownForeground" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{StaticResource DepthLineColor}" />
        <SolidColorBrush x:Key="ComboBoxItemForeground" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="ComboBoxItemBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{StaticResource DepthChrome2Color}" />
        <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="{StaticResource DepthChrome3Color}" />
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{StaticResource DepthChrome3Color}" />
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="{StaticResource DepthChrome3Color}" />
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="{StaticResource DepthChrome3Color}" />

        <!-- CheckBox + Slider accents → Depth ember (belt-and-suspenders with SystemAccentColor). -->
        <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="{StaticResource DepthEmberColor}" />
        <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="{StaticResource DepthEmberHiColor}" />
        <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="{StaticResource DepthEmberLoColor}" />
        <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="{StaticResource DepthEmberColor}" />
        <SolidColorBrush x:Key="SliderTrackValueFill" Color="{StaticResource DepthEmberColor}" />
        <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="{StaticResource DepthEmberHiColor}" />
        <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="{StaticResource DepthEmberColor}" />

        <!-- Tab header foreground per state — the Fluent TabItem template binds the label colour to
             THESE resources, so setting them (not a Style on TabItem.Foreground, which never reaches the
             inner text) is what actually controls the hover/selected colours. Inactive tabs brighten on
             hover (dim ink → full ink) to signal they're clickable; the active tab stays ember on hover
             (never white). -->
        <SolidColorBrush x:Key="TabItemHeaderForegroundUnselected" Color="{StaticResource DepthInkDimColor}" />
        <SolidColorBrush x:Key="TabItemHeaderForegroundUnselectedPointerOver" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="TabItemHeaderForegroundUnselectedPressed" Color="{StaticResource DepthInkColor}" />
        <SolidColorBrush x:Key="TabItemHeaderForegroundSelected" Color="{StaticResource DepthEmberColor}" />
        <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPointerOver" Color="{StaticResource DepthEmberColor}" />
        <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPressed" Color="{StaticResource DepthEmberColor}" />

        <!-- Section header text: light grey ink, legible on the dark Depth panels. -->
        <SolidColorBrush x:Key="SectionTextBrush" Color="{StaticResource DepthInkDimColor}" />

        <!-- Slightly rounded controls + dropdown popups everywhere (Fluent reads these). -->
        <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
        <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>

        <!-- Raised panel surface (machined grey, top-lit): a Chrome2→Chrome face + a hairline edge. -->
        <LinearGradientBrush x:Key="GlassFillGradient" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="{StaticResource DepthChrome2Color}" />
            <GradientStop Offset="1" Color="{StaticResource DepthChromeColor}" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GlassBorderGradient" Color="{StaticResource DepthLineColor}" />

        <!-- Opaque elevated surface for modal dialogs (tutorial / about): a raised Depth panel. -->
        <LinearGradientBrush x:Key="DialogFillGradient" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="{StaticResource DepthChrome2Color}" />
            <GradientStop Offset="1" Color="{StaticResource DepthChromeColor}" />
        </LinearGradientBrush>

        <!-- Buttons: a full ControlTheme so hover / press / focus read with smooth transitions
             (neutral = dark raised keycap via the styles below; .accent = ember face). -->
        <ControlTheme x:Key="{x:Type Button}" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GlassFillBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Text1Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.13" />
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.13" />
                                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.13" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter x:Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource GlassFillHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderHoverBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource GlassPressBrush}" />
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.45" />
            </Style>
            <Style Selector="^:focus-visible /template/ Border#PART_Border">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>

            <!-- Accent (primary) buttons: Classes="accent" -->
            <Style Selector="^.accent">
                <Setter Property="Background" Value="{DynamicResource AccentGradient}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style Selector="^.accent /template/ Border#PART_Border">
                <Setter Property="BoxShadow" Value="0 4 18 0 #66F25914" />
            </Style>
            <Style Selector="^.accent:pointerover">
                <Setter Property="Background" Value="{DynamicResource AccentGradientHover}" />
            </Style>
            <Style Selector="^.accent:pointerover /template/ Border#PART_Border">
                <Setter Property="BoxShadow" Value="0 7 28 0 #8AF25914" />
            </Style>
            <Style Selector="^.accent:pressed">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            </Style>
        </ControlTheme>

        <!-- Section header: a dark label with a 3px accent divider that overhangs ~25%
             past the text (a horizontal scale on the line) for an artistic flourish. -->
        <ControlTheme x:Key="{x:Type controls:SectionHeader}" TargetType="controls:SectionHeader">
            <Setter Property="Margin" Value="0,14,0,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid HorizontalAlignment="Left">
                        <TextBlock x:Name="PART_Text" Text="{TemplateBinding Text}" Margin="0,0,0,6"
                                   Foreground="{DynamicResource SectionTextBrush}"
                                   FontWeight="SemiBold" FontSize="11" />
                        <Border Height="3" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                CornerRadius="1.5" Background="{DynamicResource AccentBrush}"
                                RenderTransformOrigin="0%,50%">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.25" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Fallback for any plain section TextBlock (headers now use controls:SectionHeader). -->
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="{DynamicResource SectionTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,14,0,4" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <!-- Glass card: top-lit gradient fill, top-highlight hairline, layered shadow. -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource GlassFillGradient}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderGradient}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <!-- Layered shadows (tight contact + deep ambient) = strong elevation. -->
            <Setter Property="BoxShadow" Value="0 2 8 0 #55000000, 0 24 64 0 #8A000000" />
        </Style>

        <!-- Solid, strongly-elevated modal surface (tutorial / about): opaque fill + deep drop
             shadow so it reads as a real floating dialog, not translucent glass. -->
        <Style Selector="Border.dialog">
            <Setter Property="Background" Value="{DynamicResource DialogFillGradient}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderGradient}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BoxShadow" Value="0 8 24 0 #80000000, 0 36 90 0 #C8000000" />
        </Style>

        <!-- Etched divider under a title: a light hairline with a dark edge below it. -->
        <Style Selector="Border.divider">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="Margin" Value="0,8,0,10" />
            <Setter Property="BoxShadow" Value="0 1 0 0 #40000000" />
        </Style>

        <!-- Inner raised tile: a lighter sub-panel + soft shadow, for grouped controls. -->
        <Style Selector="Border.tile">
            <Setter Property="Background" Value="{DynamicResource GlassFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BoxShadow" Value="0 6 18 0 #5A000000" />
        </Style>

        <!-- Let the acrylic show through the tab host. -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Tab headers: ~25% smaller than the Fluent default (24 → 18), vertically centred so they
             line up with the header brandmark/wordmark band. -->
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <!-- Explicit (not Min) height + zero margin makes the tab band a deterministic 38px, so the
                 top-right header overlay (same 38px, top-anchored) centres on exactly the same line. -->
            <Setter Property="Height" Value="38" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="11,3" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <!-- Active tab: a very slight tight dark drop shadow + drop the Fluent underline ("pipe").
             The orange label colour (and the stays-orange-on-hover behaviour) comes from the
             TabItemHeaderForeground* resources above, which is what the template actually binds. -->
        <Style Selector="TabItem:selected">
            <Setter Property="Effect">
                <DropShadowEffect BlurRadius="2" Color="#000000" Opacity="0.6" OffsetX="0" OffsetY="1" />
            </Setter>
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <!-- Subtle depth on input fields: a soft drop shadow on the field's border. -->
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BoxShadow" Value="0 2 5 0 #59000000" />
        </Style>
        <Style Selector="ComboBox /template/ Border#Background">
            <Setter Property="BoxShadow" Value="0 2 5 0 #59000000" />
        </Style>

        <!-- ===== Depth controls (global) ===== -->

        <!-- Mono for numeric spinners; labels and body stay sans. -->
        <Style Selector="NumericUpDown">
            <Setter Property="FontFamily" Value="{DynamicResource DepthMono}" />
        </Style>

        <!-- Tactile press feedback. -->
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="translateY(1px)" />
        </Style>

        <!-- Neutral (non-accent) buttons: a dark raised keycap with a top-lit bevel + drop shadow,
             clearly lighter on hover. The accent (primary) button keeps its ember face. -->
        <Style Selector="Button:not(.accent)">
            <Setter Property="Background" Value="{DynamicResource DepthButtonFace}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DepthButtonBevel}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button:not(.accent) /template/ Border#PART_Border">
            <Setter Property="BoxShadow" Value="0 1 2 0 #59000000, 0 3 8 -2 #73000000" />
        </Style>
        <Style Selector="Button:not(.accent):pointerover">
            <Setter Property="Background" Value="{DynamicResource DepthButtonFaceHover}" />
        </Style>
        <Style Selector="Button:not(.accent):pointerover /template/ Border#PART_Border">
            <Setter Property="BoxShadow" Value="0 2 4 0 #66000000, 0 6 14 -3 #8C000000" />
        </Style>
        <Style Selector="Button:not(.accent):pressed">
            <Setter Property="Background" Value="{DynamicResource DepthButtonFacePressed}" />
        </Style>
        <Style Selector="Button:not(.accent):pressed /template/ Border#PART_Border">
            <Setter Property="BoxShadow" Value="0 1 1 0 #40000000" />
        </Style>
    </Application.Styles>
</Application>
