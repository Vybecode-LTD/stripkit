# Build output
bin/
obj/
out/

# Test artifacts (committed baselines stay; diff output is transient)
tests/**/output/
/teststrip*.png

# IDE
.vs/
.idea/
*.user
*.suo
*.userprefs

# Rider
*.sln.iml

# Publish / packaging — transient build outputs are ignored. The staged
# installer under releases/latest/ IS tracked: pushing it is what triggers the
# release workflow (.github/workflows/auto-release.yml).
publish/
installer/Output/
releases/*
!releases/latest/
releases/latest/*
!releases/latest/*.exe
*.app

# Large binary design sources (keep in design storage / Git LFS, not the code repo)
*.psd

# OS
.DS_Store
Thumbs.db

# Stray versioner artifact
/Version
